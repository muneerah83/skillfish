{
  "name": "skillfish",
  "version": "1.0.0",
  "description": "Install AI agent skills from GitHub with a single command",
  "type": "module",
  "bin": {
    "skillfish": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "cli",
    "skills",
    "agent-skills",
    "ai-agent",
    "ai-tools",
    "mcp",
    "claude",
    "claude-code",
    "cursor",
    "windsurf",
    "codex",
    "copilot",
    "github-copilot",
    "gemini-cli",
    "opencode",
    "goose",
    "amp",
    "roo",
    "kiro",
    "trae",
    "cline"
  ],
  "author": "Graeme Knox",
  "license": "MIT",
  "homepage": "https://skill.fish",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "degit": "^2.8.4",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
