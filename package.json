{
  "name": "install-skill",
  "version": "1.0.0",
  "description": "Install AI agent skills from GitHub with a single command",
  "type": "module",
  "bin": {
    "install-skill": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "cli",
    "skills",
    "claude",
    "claude-code",
    "cursor",
    "windsurf",
    "cline",
    "codex",
    "copilot",
    "ai-agent",
    "ai",
    "llm",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/install-skill.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/install-skill/issues"
  },
  "homepage": "https://github.com/your-org/install-skill#readme",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "degit": "^2.8.4",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
