# --- skillfish MCP gateway ---
# Your skillfish MCP gateway token. The "Deploy with Vercel" button collects
# this automatically (the `env` param). Locally, copy this file to `.env`.
SKILLFISH_MCP_TOKEN=

# Optional: override the gateway URL (defaults to https://gateway.skill.fish/mcp)
# SKILLFISH_MCP_URL=

# --- Slack channel ---
# Slack connector UID, provisioned by the Deploy button's `connect` param.
# For manual setup, run: vercel connect create slack --triggers
SLACK_CONNECTOR=
